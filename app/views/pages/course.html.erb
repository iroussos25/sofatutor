<div class="course-detail">
  <a href="/">← Back to courses</a>

  <h1><%= @course[:title] %></h1>
  <p><%= @course[:description] %></p>

  <h2>What you will learn</h2>
  <ul>
    <% @course[:topics].each do |topic| %>
      <li><%= topic %></li>
    <% end %>
  </ul>

  <a href="/signup" class="cta-button">Start Learning Free</a>
</div>